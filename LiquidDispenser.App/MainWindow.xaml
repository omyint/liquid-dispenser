<Window x:Class="LiquidDispenser.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:LiquidDispenser.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dispenser Simulator"
        Height="800"
        Width="1200"
        Background="#FF1E1E1E">
    <Window.Resources>
        <!-- Rounded Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background"
                    Value="#FF2D2D30" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="Padding"
                    Value="20,10" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FF3E3E42" />
                </Trigger>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="#FF404040" />
                    <Setter Property="Foreground"
                            Value="#FF555555" />
                    <Setter Property="Opacity"
                            Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Text Style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#FFE0E0E0" />
            <Setter Property="FontFamily"
                    Value="Segoe UI" />
        </Style>
        <!-- Card Style -->
        <Style x:Key="Card"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#FF252526" />
            <Setter Property="CornerRadius"
                    Value="15" />
            <Setter Property="Padding"
                    Value="20" />
            <Setter Property="Margin"
                    Value="10" />
            <Setter Property="BorderBrush"
                    Value="#FF3F3F46" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="4"
                                      Opacity="0.3"
                                      Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- Header & Controls -->
        <Border Grid.Row="0"
                Style="{StaticResource Card}"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Action Buttons -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <Button Content="▶ Start"
                            Command="{Binding StartSimulationCommand}"
                            Margin="0,0,10,0" />
                    <Button Content="⏹ Stop"
                            Command="{Binding StopSimulationCommand}"
                            Margin="0,0,10,0" />
                    <Button Content="↺ Reset"
                            Command="{Binding ResetSimulationCommand}" />
                </StackPanel>
                <!-- Instrument Status -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Status}"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,5"
                               Foreground="#FFA7C7E7" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Executing: "
                                   FontSize="14"
                                   Foreground="#FF888888" />
                        <TextBlock Text="{Binding CurrentJobDetails}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFD700" />
                    </StackPanel>
                </StackPanel>
                <!-- XYZ Motor Readouts -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Background="#FF1E1E1E"
                            CornerRadius="8"
                            Padding="15,10"
                            Margin="0,0,5,0">
                        <TextBlock Text="{Binding HeadX, StringFormat='X: {0:F1}'}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#FFFF6B6B" />
                    </Border>
                    <Border Background="#FF1E1E1E"
                            CornerRadius="8"
                            Padding="15,10"
                            Margin="0,0,5,0">
                        <TextBlock Text="{Binding HeadY, StringFormat='Y: {0:F1}'}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#FF4ECDC4" />
                    </Border>
                    <Border Background="#FF1E1E1E"
                            CornerRadius="8"
                            Padding="15,10">
                        <TextBlock Text="{Binding HeadZ, StringFormat='Z: {0:F1}'}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#FFFFD93D" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Source Plate -->
            <Border Grid.Column="0"
                    Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,15">
                        <TextBlock Text="{Binding PlateTitle}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="Loaded Source"
                                           FontSize="12"
                                           Foreground="#FF888888" />
                                <TextBlock Text="{Binding TotalSourceVolume, StringFormat='{}{0:F1} µL'}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#FF4ECDC4" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="Remaining Source"
                                           FontSize="12"
                                           Foreground="#FF888888" />
                                <TextBlock Text="{Binding RemainingSourceVolume, StringFormat='{}{0:F1} µL'}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#FFFFD93D" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    <Grid Grid.Row="1"
                          Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Avg Well"
                                       FontSize="12"
                                       Foreground="#FF888888"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,5" />
                            <Border BorderBrush="#FF555555"
                                    BorderThickness="2,0,2,2"
                                    Width="40"
                                    Height="100"
                                    CornerRadius="0,0,20,20"
                                    Background="#FF111111">
                                <Rectangle Fill="#FF4ECDC4"
                                           VerticalAlignment="Bottom"
                                           Height="{Binding AverageSourceFillHeight}"
                                           RadiusX="18"
                                           RadiusY="18"
                                           Margin="0,0,0,0" />
                            </Border>
                        </StackPanel>
                        <Border Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource Card}">
                            <ItemsControl Grid.Column="1"
                                          ItemsSource="{Binding PlateWells}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="{Binding PlateRows}"
                                                     Columns="{Binding PlateColumns}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#FF333333"
                                                BorderThickness="1"
                                                Background="#FF111111"
                                                ToolTip="{Binding ToolTipText}"
                                                Width="18"
                                                Height="18"
                                                Margin="1"
                                                CornerRadius="8">
                                            <Rectangle Fill="{Binding CellColor}"
                                                       VerticalAlignment="Bottom"
                                                       Height="{Binding FillHeight}"
                                                       RadiusX="8"
                                                       RadiusY="8" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
            <!-- Destination Chip -->
            <Border Grid.Column="1"
                    Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,15">
                        <TextBlock Text="{Binding ChipTitle}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                        <StackPanel HorizontalAlignment="Center"
                                    Margin="0,10,0,0">
                            <TextBlock Text="Total Dispensed"
                                       FontSize="12"
                                       Foreground="#FF888888"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalDispensedVolume, StringFormat='{}{0:F1} µL'}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#FFFF6B6B"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <Grid Grid.Row="1"
                          Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ItemsControl Grid.Column="0"
                                      ItemsSource="{Binding ChipWells}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="{Binding ChipRows}"
                                                 Columns="{Binding ChipColumns}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#FF181818"
                                            BorderThickness="1"
                                            Background="#FF0E0E0E"
                                            ToolTip="{Binding ToolTipText}"
                                            Width="6"
                                            Height="6"
                                            Margin="0">
                                        <Rectangle Fill="{Binding CellColor}"
                                                   VerticalAlignment="Bottom"
                                                   Height="{Binding FillHeight}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Grid.Column="1"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Avg Chamber"
                                       FontSize="12"
                                       Foreground="#FF888888"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,5" />
                            <Border BorderBrush="#FF555555"
                                    BorderThickness="2,0,2,2"
                                    Width="60"
                                    Height="60"
                                    CornerRadius="0,0,4,4"
                                    Background="#FF0A0A0A">
                                <Rectangle Fill="#FFFF6B6B"
                                           VerticalAlignment="Bottom"
                                           Height="{Binding AverageDestFillHeight}" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
